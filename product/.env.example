# Production Configuration Template
# Copy this file to .env and customize for your environment

# Scraper Configuration
HEADLESS_MODE=true
REQUEST_DELAY=3
TIMEOUT=60
MAX_RETRIES=3

# WebDriver Settings
WEBDRIVER_TIMEOUT=60
SELENIUM_TIMEOUT=10
PAGE_LOAD_TIMEOUT=30
IMPLICIT_WAIT=5
WINDOW_SIZE_WIDTH=1920
WINDOW_SIZE_HEIGHT=1080

# Rate Limiting
MIN_DELAY=1.0
MAX_DELAY=3.0
REQUESTS_PER_MINUTE=20
REQUESTS_PER_HOUR=100

# Session Management
SESSION_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# API Configuration
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5002
